PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quotesnap
JWT_ACCESS_SECRET=change-me-use-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-use-a-different-long-random-string-in-production

# Cloudflare R2 (audio storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=quotesnap-audio

# OpenAI (Whisper + GPT-4o)
OPENAI_API_KEY=your-openai-api-key
